---
import { SITE, withBase } from '../data/seo';
import ThemeToggle from './ThemeToggle.astro';
const nav = [
  { label: 'Features', href: withBase('/#features') },
  { label: 'Docs', href: withBase('/docs/overview') },
  { label: 'FAQ', href: withBase('/faq') },
];
---
<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href={withBase('/')} class="flex items-center gap-2" aria-label={`${SITE.shortName} home`}>
      <svg viewBox="0 0 76 56" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-7 w-auto text-slate-900 dark:text-white" aria-hidden="true" focusable="false">
        <path d="M14 11 H46 A4 4 0 0 1 50 15 V24 A4 4 0 0 0 50 32 V41 A4 4 0 0 1 46 45 H14 A4 4 0 0 1 10 41 V34 A4 4 0 0 0 10 22 V15 A4 4 0 0 1 14 11 Z" stroke="currentColor" stroke-width="3.2" stroke-linejoin="round" />
        <g fill="currentColor">
          <rect x="19" y="20" width="9" height="3.2" rx="0.4" />
          <rect x="22" y="20" width="3.2" height="16" rx="0.4" />
          <rect x="19" y="32.8" width="9" height="3.2" rx="0.4" />
          <rect x="30" y="20" width="13" height="3.2" rx="0.4" />
          <rect x="34.9" y="20" width="3.2" height="16" rx="0.4" />
        </g>
        <circle cx="55" cy="39" r="14" class="fill-white dark:fill-slate-950" />
        <circle cx="55" cy="39" r="12" stroke="currentColor" stroke-width="3.2" />
        <g fill="currentColor">
          <circle cx="55" cy="33.5" r="1.9" />
          <rect x="53.2" y="37" width="3.6" height="9.5" rx="0.6" />
        </g>
      </svg>
      <span class="font-semibold text-slate-900 dark:text-white">{SITE.shortName}</span>
    </a>
    <nav class="flex items-center gap-1 text-sm" aria-label="Primary">
      {nav.map((n) => (
        <a href={n.href} class="rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white">{n.label}</a>
      ))}
      <a href={SITE.repo} class="rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white">GitHub</a>
      <ThemeToggle />
    </nav>
  </div>
</header>
